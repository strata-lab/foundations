# Copy this file to .env.local for local development
# Run `vercel env pull .env.local` to sync from Vercel (overwrites)

# Sentry — create a project at sentry.io and grab the DSN from Settings > Client Keys
# The Next.js config re-exposes this as NEXT_PUBLIC_SENTRY_DSN for the client bundle.
SENTRY_DSN=https://xxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# Required for source map uploads during production builds.
# Create a token at sentry.io: Settings > Auth Tokens > Create New Token (project:releases scope)
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=foundations
