# Public site URL — set this to your production domain or Vercel URL
NEXT_PUBLIC_SITE_URL=https://strataconsult.io

# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=hello@strataconsult.io

# The From address for outbound email (must be a verified domain in Resend)
CONTACT_FROM_EMAIL=noreply@strataconsult.io
