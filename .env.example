# Public site URL — set this to your production domain or Vercel URL
NEXT_PUBLIC_SITE_URL=https://strataconsult.io

# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=hello@strataconsult.io

# The From address for outbound email (must be a verified domain in Resend)
CONTACT_FROM_EMAIL=noreply@strataconsult.io

# Sentry DSN — get from sentry.io: Settings > Projects > <project> > Client Keys (DSN)
# This is the only Sentry var you need to store in Vercel env. Next.js re-exposes it to the
# client bundle automatically. When set, errors are captured and /api/sentry-test fires a test event.
SENTRY_DSN=https://xxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# Required for source map uploads on production builds.
# Create an auth token at sentry.io: Settings > Auth Tokens > Create New Token (project:releases scope).
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=strata-site
